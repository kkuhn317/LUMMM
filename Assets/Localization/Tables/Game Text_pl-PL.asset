  - m_Id: 55487228821499904
    m_Localized: "<color=#FF0000>Uwaga:</color> Zmiana modyfikator\xF3w <color=#FFA500>zresetuje
      twoje punkty kontrolne.</color> <color=#00FF00>\nCzy na pewno chcesz kontynuowa\u0107?</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 55487244151681024
    m_Localized: "Tak, zmie\u0144 modyfikatory"
    m_Metadata:
      m_Items: []
  - m_Id: 55487253681139712
    m_Localized: Nie, nie zmieniaj
    m_Metadata:
      m_Items: []
  - m_Id: 55518017419730944
    m_Localized: "Do kt\xF3rego punktu chcesz si\u0119 cofa\u0107?"
    m_Metadata:
      m_Items: []
  - m_Id: 55518276367671296
    m_Localized: "Na pocz\u0105tek"
    m_Metadata:
      m_Items: []
  - m_Id: 55518310266036224
    m_Localized: Do ostatniego punktu kontrolnego
    m_Metadata:
      m_Items: []
