  - m_Id: 207392259977621504
    m_Localized: Kopiuj
    m_Metadata:
      m_Items: []
  - m_Id: 207392286485622784
    m_Localized: "Usu\u0144"
    m_Metadata:
      m_Items: []
  - m_Id: 213770868993687552
    m_Localized: "Unieszkodliw wielk\u0105 wyrzutni\u0119 kul-bill\xF3w, aby wygra\u0107!"
    m_Metadata:
      m_Items: []
  - m_Id: 207392745933877248
    m_Localized: Wybierz zapis
    m_Metadata:
      m_Items: []
  - m_Id: 215002748625485824
    m_Localized: "Wybierz zapis do usuni\u0119cia"
    m_Metadata:
      m_Items: []
  - m_Id: 215002749560815616
    m_Localized: Wybierz zapis do skopiowania
    m_Metadata:
      m_Items: []
  - m_Id: 215002750588420096
