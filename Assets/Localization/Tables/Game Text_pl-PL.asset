    m_Metadata:
      m_Items: []
  - m_Id: 215033281858371584
    m_Localized: "W tym slocie ju\u017C znajduje si\u0119 zapis. Czy chcesz go zast\u0105pi\u0107?"
    m_Metadata:
      m_Items: []
  - m_Id: 215037903197044736
    m_Localized: "W tym slocie ju\u017C znajduje si\u0119 zapis. Czy chcesz go zast\u0105pi\u0107?"
    m_Metadata:
      m_Items: []
  - m_Id: 215040186265763840
    m_Localized: "Czy chcesz usun\u0105\u0107 ten zapis? Tej czynno\u015Bci nie mo\u017Cna
      cofn\u0105\u0107."
    m_Metadata:
      m_Items: []
  - m_Id: 215040353253588992
    m_Localized: Tak
    m_Metadata:
      m_Items: []
  - m_Id: 215040355614982144
